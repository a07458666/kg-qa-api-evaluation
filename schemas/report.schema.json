{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/kg-qa-api-evaluation/schemas/report.schema.json",
  "title": "Evaluation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "timestamp",
    "project_name",
    "environment_name",
    "mode",
    "total_cases",
    "passed_cases",
    "failed_cases",
    "schema_failures",
    "case_results"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "project_name": { "type": "string", "minLength": 1 },
    "environment_name": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["smoke", "quality", "regression", "full"] },
    "git_commit": { "type": "string" },
    "total_cases": { "type": "integer", "minimum": 0 },
    "passed_cases": { "type": "integer", "minimum": 0 },
    "failed_cases": { "type": "integer", "minimum": 0 },
    "average_latency_ms": { "type": "number", "minimum": 0 },
    "schema_failures": { "type": "integer", "minimum": 0 },
    "presentation": { "$ref": "#/$defs/PresentationConfig" },
    "kg_summary": { "$ref": "#/$defs/KgRunSummary" },
    "qa_summary": { "$ref": "#/$defs/QaRunSummary" },
    "regression_summary": { "$ref": "#/$defs/RegressionSummary" },
    "case_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/CaseResult" }
    }
  },
  "$defs": {
    "GraphRendererConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["library", "layout"],
      "properties": {
        "library": { "type": "string", "enum": ["d3"] },
        "layout": { "type": "string", "enum": ["force", "radial", "dagre-like"] },
        "directed": { "type": "boolean" },
        "zoom": { "type": "boolean" },
        "pan": { "type": "boolean" },
        "drag": { "type": "boolean" },
        "show_legend": { "type": "boolean" },
        "show_minimap": { "type": "boolean" },
        "default_node_label_field": { "type": "string", "minLength": 1 },
        "default_node_group_field": { "type": "string", "minLength": 1 },
        "default_edge_label_field": { "type": "string", "minLength": 1 }
      }
    },
    "QaRendererConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format"],
      "properties": {
        "format": { "type": "string", "enum": ["markdown"] },
        "flavor": { "type": "string", "enum": ["gfm", "commonmark"] },
        "allow_tables": { "type": "boolean" },
        "allow_bold": { "type": "boolean" },
        "allow_italic": { "type": "boolean" },
        "allow_lists": { "type": "boolean" },
        "allow_blockquotes": { "type": "boolean" },
        "allow_code": { "type": "boolean" },
        "sanitize_html": { "type": "boolean" }
      }
    },
    "PresentationConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "graph_renderer": { "$ref": "#/$defs/GraphRendererConfig" },
        "qa_renderer": { "$ref": "#/$defs/QaRendererConfig" }
      }
    },
    "KgRunSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_cases",
        "passed_cases",
        "failed_cases",
        "invalid_relation_count",
        "duplicate_entity_count",
        "duplicate_relation_count",
        "forbidden_hit_count"
      ],
      "properties": {
        "total_cases": { "type": "integer", "minimum": 0 },
        "passed_cases": { "type": "integer", "minimum": 0 },
        "failed_cases": { "type": "integer", "minimum": 0 },
        "avg_entity_match_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "avg_relation_match_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "invalid_relation_count": { "type": "integer", "minimum": 0 },
        "duplicate_entity_count": { "type": "integer", "minimum": 0 },
        "duplicate_relation_count": { "type": "integer", "minimum": 0 },
        "forbidden_hit_count": { "type": "integer", "minimum": 0 }
      }
    },
    "QaRunSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_cases",
        "passed_cases",
        "failed_cases",
        "forbidden_keyword_hit_count",
        "citation_pass_count",
        "abstention_pass_count"
      ],
      "properties": {
        "total_cases": { "type": "integer", "minimum": 0 },
        "passed_cases": { "type": "integer", "minimum": 0 },
        "failed_cases": { "type": "integer", "minimum": 0 },
        "avg_expected_keyword_hit_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "forbidden_keyword_hit_count": { "type": "integer", "minimum": 0 },
        "citation_pass_count": { "type": "integer", "minimum": 0 },
        "abstention_pass_count": { "type": "integer", "minimum": 0 },
        "groundedness_rule_pass_count": { "type": "integer", "minimum": 0 }
      }
    },
    "RegressionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_report_path",
        "is_regression_detected",
        "metrics_delta"
      ],
      "properties": {
        "baseline_report_path": { "type": "string", "minLength": 1 },
        "is_regression_detected": { "type": "boolean" },
        "metrics_delta": { "type": "object" },
        "worsened_cases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "improved_cases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "gating_result": { "type": "string", "enum": ["pass", "fail"] }
      }
    },
    "GraphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "group": { "type": "string" },
        "status": { "type": "string" },
        "raw_text": { "type": "string" },
        "meta": { "type": "object" }
      }
    },
    "GraphLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target", "label"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "status": { "type": "string" },
        "meta": { "type": "object" }
      }
    },
    "GraphPresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["renderer", "nodes", "links"],
      "properties": {
        "renderer": { "type": "string", "enum": ["d3-force"] },
        "title": { "type": "string" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphNode" }
        },
        "links": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphLink" }
        },
        "legend": { "type": "object" },
        "style_hints": { "type": "object" }
      }
    },
    "MarkdownSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "markdown"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "markdown": { "type": "string" }
      }
    },
    "MarkdownCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "markdown"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "markdown": { "type": "string" }
      }
    },
    "QaPresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["render_mode", "answer_markdown"],
      "properties": {
        "render_mode": { "type": "string", "enum": ["markdown"] },
        "answer_markdown": { "type": "string" },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/MarkdownSection" }
        },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/MarkdownCitation" }
        },
        "style_hints": { "type": "object" }
      }
    },
    "CasePresentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "graph": { "$ref": "#/$defs/GraphPresentation" },
        "qa": { "$ref": "#/$defs/QaPresentation" }
      }
    },
    "CaseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "endpoint_type", "status", "failure_reasons"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "endpoint_type": { "type": "string", "enum": ["kg", "qa"] },
        "status": { "type": "string", "enum": ["passed", "failed", "error"] },
        "latency_ms": { "type": "number", "minimum": 0 },
        "failure_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "request_payload": { "type": "object" },
        "normalized_output": { "type": "object" },
        "presentation": { "$ref": "#/$defs/CasePresentation" },
        "raw_response": {
          "oneOf": [
            { "type": "object" },
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "metrics": { "type": "object" }
      }
    }
  }
}
